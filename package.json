{
  "name": "compare",
  "displayName": "Compare",
  "version": "0.1.0",
  "description": "Universal price tracker, value analyzer, and product comparison tool",
  "author": "",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@plasmohq/messaging": "^0.7.0",
    "@plasmohq/storage": "^1.13.0",
    "plasmo": "^0.90.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.12.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "3.4.17",
    "typescript": "^5.7.3"
  },
  "manifest": {
    "host_permissions": [
      "https://www.amazon.com/*",
      "https://www.amazon.co.uk/*",
      "https://www.walmart.com/*",
      "https://www.target.com/*",
      "https://www.bestbuy.com/*",
      "https://www.ebay.com/*",
      "https://www.newegg.com/*",
      "https://www.google.com/search*",
      "https://openrouter.ai/*"
    ],
    "permissions": [
      "storage"
    ]
  }
}
